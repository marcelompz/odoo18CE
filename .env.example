# Odoo 18 CE - Ejemplo de configuración para Docker Compose
# Copia este archivo a .env y configura tus valores

# ====================
# Configuración general
# ====================
TZ=America/Argentina/Buenos_Aires
DEBIAN_FRONTEND=noninteractive

# ====================
# Configuración de red
# ====================
NETWORK_SUBNET=172.23.0.0/16

# ====================
# Configuración del servicio web Odoo
# ====================
WEB_HOST=odoo_web
WEB_IMAGE_NAME=odoo
WEB_IMAGE_TAG=18.0
WEB_PORT=8069
WEB_BUILD=.
LONGPOLLING_PORT=8072

# Rutas de addons (ajusta según tu entorno)
WEB_ADDONS_CUSTOMIZE=/path/to/your/custom-addons
WEB_ADDONS_L10NPY=/path/to/your/l10n-addons
WEB_VOLUMES=./odoo-web-data

# ====================
# Configuración del servicio de base de datos
# ====================
DB_IMAGE=postgres
DB_TAG=15-alpine
DB_HOST=db_odoo
DB_PORT=5439
DB_NAME=odoo_production
DB_USER=odoo
# ⚠️ CAMBIA ESTA CONTRASEÑA POR UNA SEGURA ⚠️
DB_PASSWD=your_secure_password_here
DB_VOLUMES=./odoo-db-data

# ====================
# Configuración de PostgreSQL optimizada
# ====================
POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB

# ====================
# Configuración de Odoo optimizada
# ====================
ODOO_LIMIT_MEMORY_HARD=2684354560
ODOO_LIMIT_MEMORY_SOFT=2147483648
ODOO_LIMIT_REQUEST=8192
ODOO_LIMIT_TIME_CPU=600
ODOO_LIMIT_TIME_REAL=1200
ODOO_WORKERS=4